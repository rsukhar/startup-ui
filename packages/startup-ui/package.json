{
    "name": "startup-ui",
    "version": "0.12.0",
    "description": "Vue3 UI components for IT startups. Best served with Laravel + InertiaJS",
    "type": "module",
    "main": "dist/startup-ui.cjs.js",
    "module": "dist/startup-ui.es.js",
    "types": "dist/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/startup-ui.es.js",
            "require": "./dist/startup-ui.cjs.js"
        },
        "./dist/index.css": "./dist/index.css",
        "./defaults.css": "./dist/defaults.css"
    },
    "files": [
        "dist"
    ],
    "sideEffects": [
        "**/*.css",
        "**/*.scss"
    ],
    "peerDependencies": {
        "@inertiajs/vue3": "^2.0.0 || ^3.0.0",
        "@vueuse/core": "^14.0.0",
        "vue": "^3.5.0"
    },
    "peerDependenciesMeta": {
        "@inertiajs/vue3": {
            "optional": true
        }
    },
    "devDependencies": {
        "@fortawesome/vue-fontawesome": "^3.2.0",
        "@inertiajs/vue3": "^3.2.0",
        "@types/node": "^25.9.1",
        "@types/sortablejs": "^1.15.9",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vueuse/core": "^14.3.0",
        "dayjs": "^1.11.21",
        "sass-embedded": "^1.100.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.14",
        "vite-plugin-dts": "^4.5.4",
        "vue": "^3.5.34",
        "vue-tsc": "^3.3.2"
    },
    "scripts": {
        "build": "vite build",
        "typecheck": "vue-tsc --noEmit",
        "dev": "vite"
    },
    "license": "MIT",
    "dependencies": {
        "@vueuse/integrations": "^14.3.0",
        "axios": "^1.16.1",
        "sortablejs": "^1.15.7"
    }
}
